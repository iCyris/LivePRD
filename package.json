{
  "name": "live-prd",
  "version": "0.7.0",
  "description": "CLI and starter workspace for living Markdown PRDs with embedded React demos.",
  "private": false,
  "type": "module",
  "packageManager": "bun@latest",
  "bin": {
    "live-prd": "./packages/cli/index.mjs"
  },
  "files": [
    "apps",
    "packages",
    "skills",
    "scripts",
    "themes",
    "demos",
    "docs/prd/*.md",
    "live-prd.config.json",
    "README.md"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "live-prd": "node ./packages/cli/index.mjs",
    "cli": "node ./packages/cli/index.mjs",
    "init": "node ./packages/cli/index.mjs init",
    "doctor": "node ./packages/cli/index.mjs doctor",
    "validate": "node ./packages/cli/index.mjs validate",
    "render": "node ./packages/cli/index.mjs render",
    "dev": "node ./packages/cli/index.mjs dev",
    "build": "node ./packages/cli/index.mjs build",
    "preview": "node ./packages/cli/index.mjs preview",
    "skill:install": "node ./packages/cli/index.mjs skill-install",
    "release:local": "node ./packages/cli/index.mjs release-local"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.18"
  }
}
